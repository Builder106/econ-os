# Copy to .env on the VM (`cp .env.example .env`) and edit values.
# .env is read by docker-compose; never commit it (gitignored).

# Cloudflare Tunnel token (from: Zero Trust → Networks → Tunnels → your tunnel
# → Install connector → "Save tunnel" reveals a long base64 string).
# This is a credential — treat it like a password.
TUNNEL_TOKEN=

# Long random string. Anyone with this string can issue admin shell commands.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# Comma-separated list of frontend origins, or "*" to allow any.
# After Vercel deploys, tighten this to your exact dashboard URL:
#   ALLOWED_ORIGINS=https://your-econos.vercel.app
ALLOWED_ORIGINS=*
