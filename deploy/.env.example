# Copy to .env on the VM (`cp .env.example .env`) and edit values.
# .env is read by docker-compose; never commit it (gitignored).

# Long random string. Anyone with this string can issue admin shell commands.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# CORS — exact-match list of allowed dashboard origins. The Vercel production
# deploy is sufficient for most cases. Use '*' only as a temporary loosening
# during initial deploy; tighten before sharing the link publicly.
ALLOWED_ORIGINS=https://econ-os.vercel.app

# Optional regex to also allow Vercel preview deployments (per-branch URLs
# under your team subdomain). Vercel project URLs typically look like:
#   econ-os-git-<branch>-<team>.vercel.app
# Replace <team> with your Vercel team slug if you want previews to connect.
# Leave empty to deny previews.
ALLOWED_ORIGIN_REGEX=^https://econ-os-git-[a-z0-9-]+-sankofa-forge\.vercel\.app$
